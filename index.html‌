            var items = [];
            var iframeUrl = null;
            var linkUrl = null;

            for (var i = 0; i < allData.length; i++) {
                var d = allData[i];
                if (category === '平台') {
                    if (d.parent === '平台' && d.tag === sub) {
                        if (d.isNoticeIframe) {
                            iframeUrl = d.url;
                        } else if (d.isNoticeLink) {
                            linkUrl = d.url;
                        } else {
                            items.push(d);
                        }
                    }
                } else if (category === '跨境') {
                    if (d.parent === '跨境' && d.tag === sub) {
                        items.push(d);
                    }
                } else {
                    if (d.tag === category && !d.parent) {
                        items.push(d);
                    }
                }
            }

            var title = category === '平台' ? sub : category;
            document.getElementById('categoryTitle').innerHTML = title + ' <span class="count">' + items.length +
            ' 个工具</span>';

            var resultList = document.getElementById('resultList');
            var html = '';
            if (items.length === 0) {
                html = '<div class="empty">📭 暂无工具</div>';
            } else {
                html = '<div class="card-grid">';
                for (var k = 0; k < items.length; k++) {
                    var it = items[k];
                    var noticeClass = it.isNotice ? ' card-item notice' : '';
                    var promoClass = it.isPromotion ? ' card-item promotion' : '';
                    var finalClass = noticeClass || promoClass;
                    html += '<div class="card-item' + (finalClass ? ' ' + finalClass : '') + '">';
                    html += '<span class="name">' + it.name +
                        (it.isPromotion ? ' <span class="badge-hot">HOT</span>' : '') +
                        '</span>';
                    if (it.url) {
                        html += '<a href="' + it.url + '" target="_blank" class="url">前往 →</a>';
                    } else {
                        html += '<span style="font-size:12px;color:#94a3b8;">待补充</span>';
                    }
                    html += '</div>';
                }
                html += '</div>';
            }
            resultList.innerHTML = html;

            var noticeContainer = document.getElementById('noticeContainer');
            noticeContainer.innerHTML = '';

            if (iframeUrl && category === '平台') {
                var wrapper = document.createElement('div');
                wrapper.className = 'notice-iframe-wrapper';
                wrapper.innerHTML = '<div class="iframe-loading">⏳ 加载公告中...</div>' +
                    '<iframe src="' + iframeUrl +
                    '" onload="this.previousElementSibling.style.display=\'none\'" onerror="this.previousElementSibling.textContent=\'⚠️ 公告加载失败\'"></iframe>';
                noticeContainer.appendChild(wrapper);
            } else if (linkUrl && category === '平台') {
                var linkWrapper = document.createElement('a');
                linkWrapper.className = 'notice-link-wrapper';
                linkWrapper.href = linkUrl;
                linkWrapper.target = '_blank';
