                    html = '<div class="empty">📭 暂无工具</div>';
                } else {
                    html = '<div class="card-grid">';
                    for (var k = 0; k < items.length; k++) {
                        var it = items[k];
                        var noticeClass = it.isNotice ? ' card-item notice' : '';
                        var promoClass = it.isPromotion ? ' card-item promotion' : '';
                        var finalClass = noticeClass || promoClass;
                        html += '<div class="card-item' + (finalClass ? ' ' + finalClass : '') + '">';
                        html += '<span class="name">' + it.name +
                            (it.isPromotion ? ' <span class="badge-hot">HOT</span>' : '') +
                            '</span>';
                        if (it.url) {
                            html += '<a href="' + it.url + '" target="_blank" class="url">前往 →</a>';
                        } else {
                            html += '<span style="font-size:12px;color:#94a3b8;">待补充</span>';
                        }
                        html += '</div>';
                    }
                    html += '</div>';
                }
                resultList.innerHTML = html;
                document.getElementById('noticeContainer').innerHTML = '';
            });
        });

        // ============================================================
        //  首页搜索
        // ============================================================
        document.getElementById('searchInput').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                var kw = this.value.trim().toLowerCase();
                if (!kw) {
                    document.getElementById('homePage').style.display = 'flex';
                    document.getElementById('contentArea').classList.remove('show');
                    return;
                }

                var results = [];
                for (var i = 0; i < allData.length; i++) {
                    var d = allData[i];
                    if (d.isNoticeIframe || d.isNoticeLink) continue;
                    if (d.name.includes(kw) || (d.url && d.url.includes(kw))) {
                        results.push(d);
                    }
                }

                document.getElementById('homePage').style.display = 'none';
                document.getElementById('contentArea').classList.add('show');
                document.getElementById('knowledgeContainer').classList.remove('show');
                document.getElementById('solutionSplit').style.display = 'none';
                document.getElementById('otherCategoryContainer').style.display = 'flex';
                document.getElementById('categoryTitle').innerHTML = '搜索结果 <span class="count">' + results.length +
                    ' 个结果</span>';

                var resultList = document.getElementById('resultList');
                if (results.length === 0) {
                    resultList.innerHTML = '<div class="empty">🔍 没有找到匹配的内容</div>';
                } else {
                    var html = '<div class="card-grid">';
                    for (var k = 0; k < results.length; k++) {
                        var it = results[k];
                        var tagDisplay = it.parent === '平台' ? it.tag : it.tag;
                        var noticeClass = it.isNotice ? ' card-item notice' : '';
                        html += '<div class="card-item' + noticeClass + '">';
                        html += '<span class="name"><span class="tag">' + tagDisplay + '</span> ' + it.name +
                            '</span>';
                        if (it.url) {
                            html += '<a href="' + it.url + '" target="_blank" class="url">前往 →</a>';
                        } else {
                            html += '<span style="font-size:12px;color:#94a3b8;">待补充</span>';
                        }
                        html += '</div>';
                    }
                    html += '</div>';
                    resultList.innerHTML = html;
                }
                document.getElementById('noticeContainer').innerHTML = '';
            }
        });

        document.getElementById('clearBtn').addEventListener('click', function() {
            document.getElementById('searchInput').value = '';
            this.classList.remove('show');
            document.getElementById('homePage').style.display = 'flex';
            document.getElementById('contentArea').classList.remove('show');
            document.getElementById('searchInput').focus();
        });

        document.getElementById('searchInput').addEventListener('input', function() {
            var val = this.value.trim();
            document.getElementById('clearBtn').classList.toggle('show', val.length > 0);
        });

        document.getElementById('searchInput').addEventListener('focus', function() {
            if (this.value.trim()) {
                document.getElementById('clearBtn').classList.add('show');
            }
        });

        document.getElementById('searchInput').addEventListener('blur', function() {
            setTimeout(function() {
                document.getElementById('clearBtn').classList.remove('show');
            }, 200);
        });

        document.querySelectorAll('.quick-tags .tag').forEach(function(tag) {
            tag.addEventListener('click', function() {
                var cat = this.dataset.category;
                document.querySelectorAll('.sidebar .nav-item[data-category]').forEach(function(item) {
                    if (item.getAttribute('data-category') === cat) {
                        item.click();
                    }
                });
            });
        });

        // ============================================================
        //  更新日志
        // ============================================================
        var changelogData = [{
            date: '2026-06-20',
            version: 'v1.6.0',
            items: [
                { text: '知识库新增标签筛选栏：工单系统培训、OFS系统培训、OMS系统培训、Cyberlink系统培训', type: 'new' },
                { text: '知识库4列×4行大卡片布局，支持关键词搜索', type: 'new' },
                { text: '左侧知识库不再展开子菜单，简洁统一', type: 'update' },
                { text: '解决方案左右分栏列表 + 独立搜索 + 分页', type: 'new' },
                { text: '跨境菜单默认折叠，点击展开', type: 'update' }
            ]
        }, {
            date: '2026-06-20',
            version: 'v1.5.0',
            items: [
                { text: '将「文档知识库」更名为「知识库」', type: 'update' },
                { text: '新增一级菜单「解决方案」', type: 'new' },
                { text: '解决方案分类新增5个方案', type: 'new' }
            ]
        }, {
            date: '2026-06-20',
            version: 'v1.4.0',
            items: [
                { text: '跨境分类新增平台图标及 Cyberlink 接口', type: 'new' },
                { text: '新增一级分类「跨境」', type: 'new' },
                { text: '修复左侧菜单折叠/展开交互问题', type: 'fix' }
            ]
        }, {
            date: '2026-06-20',
            version: 'v1.3.0',
            items: [
                { text: '文档知识库新增「Cyberlink」文档入口', type: 'new' },
                { text: '内部系统新增「Cyberlink沙盒」与「Cyberlink生产」入口', type: 'new' }
            ]
        }, {
            date: '2026-06-20',
            version: 'v1.2.0',
            items: [
                { text: '新增「首页」居中搜索入口', type: 'new' },
                { text: '平台分类新增 18 个电商平台 API 文档入口', type: 'new' },
                { text: '新增版本更新日志弹窗（右上角）', type: 'new' }
            ]
        }];

        function renderChangelog() {
            var html = '';
            for (var i = 0; i < changelogData.length; i++) {
                var entry = changelogData[i];
                html += '<div class="changelog-item">';
                html += '<span class="date">' + entry.date + '</span>';
                html += '<span class="version-tag">' + entry.version + '</span>';
                html += '<ul>';
                for (var j = 0; j < entry.items.length; j++) {
                    var item = entry.items[j];
                    var tag = '';
                    if (item.type === 'new') tag = '<span class="tag-new">新增</span>';
                    else if (item.type === 'fix') tag = '<span class="tag-fix">修复</span>';
                    else if (item.type === 'update') tag = '<span class="tag-update">优化</span>';
                    html += '<li>' + item.text + ' ' + tag + '</li>';
                }
                html += '</ul>';
                html += '</div>';
            }
            document.getElementById('changelogContent').innerHTML = html;
        }
        renderChangelog();

        document.getElementById('changelogBtn').addEventListener('click', function() {
            document.getElementById('changelogModal').classList.add('show');
        });
        document.getElementById('modalCloseBtn').addEventListener('click', function() {
            document.getElementById('changelogModal').classList.remove('show');
        });
        document.getElementById('changelogModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });

        // ============================================================
        //  初始化 —— 默认显示首页，平台展开，跨境折叠
        // ============================================================
        // 1. 首页可见，内容区隐藏
        document.getElementById('homePage').style.display = 'flex';
        document.getElementById('contentArea').classList.remove('show');

        // 2. 侧边栏高亮首页
        document.querySelectorAll('.sidebar .nav-item[data-category]').forEach(function(item) {
            item.classList.remove('active');
            if (item.getAttribute('data-category') === '首页') {
                item.classList.add('active');
            }
        });

        // 3. 平台菜单：展开
        document.getElementById('platformSub').classList.add('open');
        document.getElementById('platformArrow').classList.add('open');

        // 4. 跨境菜单：折叠
        document.getElementById('crossBorderSub').classList.remove('open');
        document.getElementById('crossBorderArrow').classList.remove('open');

        // 5. 清除子项高亮
        document.querySelectorAll('#platformSub .sub-item, #crossBorderSub .sub-item').forEach(function(el) {
            el.classList.remove('active');
        });
    </script>
</body>
</html>