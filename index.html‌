        function PanelManager(panelId, searchId, platformId, tagId, resetId, tbodyId, countId, pageInfoId, pagesId) {
            this.panelId = panelId;
            this.searchInput = document.getElementById(searchId);
            this.platformFilter = document.getElementById(platformId);
            this.tagFilter = document.getElementById(tagId);
            this.resetBtn = document.getElementById(resetId);
            this.tbody = document.getElementById(tbodyId);
            this.countEl = document.getElementById(countId);
            this.pageInfo = document.getElementById(pageInfoId);
            this.pagesEl = document.getElementById(pagesId);

            this.currentPage = 1;
            this.pageSize = 20;
            this.filteredData = [];

            var self = this;

            this.searchInput.addEventListener('input', function() { self.currentPage = 1;
                self.render(); });
            this.platformFilter.addEventListener('change', function() { self.currentPage = 1;
                self.render(); });
            this.tagFilter.addEventListener('change', function() { self.currentPage = 1;
                self.render(); });
            this.resetBtn.addEventListener('click', function() {
                self.searchInput.value = '';
                self.platformFilter.value = '';
                self.tagFilter.value = '';
                self.currentPage = 1;
                self.render();
            });

            renderFilterOptions(this.platformFilter, this.tagFilter);

            this.render = function() {
                var search = this.searchInput.value.trim().toLowerCase();
                var plat = this.platformFilter.value;
                var tag = this.tagFilter.value;

                this.filteredData = solutionData.filter(function(d) {
                    var matchName = d.name.toLowerCase().includes(search) || d.desc.toLowerCase().includes(search);
                    var matchPlat = !plat || d.platform === plat;
                    var matchTag = !tag || d.tags.indexOf(tag) !== -1;
                    return matchName && matchPlat && matchTag;
                });

                var total = this.filteredData.length;
                var totalPages = Math.ceil(total / this.pageSize) || 1;
                if (this.currentPage > totalPages) this.currentPage = totalPages;
                var start = (this.currentPage - 1) * this.pageSize;
                var end = Math.min(start + this.pageSize, total);
                var pageData = this.filteredData.slice(start, end);

                var html = '';
                if (pageData.length === 0) {
                    html = '<tr><td colspan="4" style="text-align:center;padding:30px 0;color:#94a3b8;">📭 没有匹配的方案</td></tr>';
                } else {
                    for (var i = 0; i < pageData.length; i++) {
                        var d = pageData[i];
                        var logo = platformLogos[d.platform] || '';
                        var tagHtml = '';
                        for (var j = 0; j < d.tags.length; j++) {
                            var colorClass = tagColors[(i + j) % tagColors.length];
                            tagHtml += '<span class="tag ' + colorClass + '">' + d.tags[j] + '</span>';
                        }
                        html += '<tr>' +
                            '<td class="col-name">' + d.name + '<span class="desc">' + d.desc + '</span></td>' +
                            '<td><div class="col-platform">' +
                            (logo ? '<img class="logo" src="' + logo + '" onerror="this.style.display=\'none\'" />' : '') +
                            d.platform + '</div></td>' +
                            '<td><div class="col-tags">' + tagHtml + '</div></td>' +
                            '<td class="col-action"><a href="' + d.url + '" class="btn" target="_blank">查看 →</a></td>' +
                            '</tr>';
                    }
                }
                this.tbody.innerHTML = html;

                this.countEl.innerHTML = '共 <strong>' + total + '</strong> 个';
                this.pageInfo.innerHTML = '显示 <strong>' + (total > 0 ? start + 1 : 0) + '</strong>-<strong>' + end +
                    '</strong> 条';

                var pageHtml = '';
                pageHtml += '<button onclick="window._goPage(\'' + this.panelId + '\',' + (this.currentPage - 1) +
                    ')" ' + (this.currentPage <= 1 ? 'disabled' : '') + '>‹</button>';
                for (var p = 1; p <= totalPages; p++) {
                    if (p === this.currentPage) {
                        pageHtml += '<button class="active">' + p + '</button>';
                    } else if (p <= 3 || p > totalPages - 2 || Math.abs(p - this.currentPage) <= 1) {
                        pageHtml += '<button onclick="window._goPage(\'' + this.panelId + '\',' + p + ')">' + p +
                        '</button>';
                    } else if (p === 4 || p === totalPages - 3) {
                        pageHtml += '<button disabled>…</button>';
                    }
                }
                pageHtml += '<button onclick="window._goPage(\'' + this.panelId + '\',' + (this.currentPage + 1) +
                    ')" ' + (this.currentPage >= totalPages ? 'disabled' : '') + '>›</button>';
                this.pagesEl.innerHTML = pageHtml;
            };

            this.goPage = function(p) {
                var total = this.filteredData.length;
                var totalPages = Math.ceil(total / this.pageSize) || 1;
                if (p < 1 || p > totalPages) return;
                this.currentPage = p;
                this.render();
            };

            window['_panel_' + panelId] = this;
        }

