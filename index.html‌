        function showCategoryContent(category, sub) {
            document.getElementById('homePage').style.display = 'none';
            document.getElementById('contentArea').classList.add('show');
            document.getElementById('knowledgeContainer').classList.remove('show');
            document.getElementById('solutionSplit').style.display = 'none';
