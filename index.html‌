            for (var p = 1; p <= totalPages; p++) {
                if (p === knowledgeCurrentPage) {
                    btnHtml += '<button class="active">' + p + '</button>';
                } else if (p <= 2 || p > totalPages - 2 || Math.abs(p - knowledgeCurrentPage) <= 1) {
                    btnHtml += '<button onclick="goKnowledgePage(' + p + ')">' + p + '</button>';
